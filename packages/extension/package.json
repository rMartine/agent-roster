{
  "name": "agent-forge",
  "displayName": "Agent Forge",
  "description": "Deploy, restore, wipe, and check status of your AI agent roster",
  "version": "0.1.0",
  "publisher": "agent-forge",
  "icon": "media/agent-forge-icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:agentForge.dashboard",
    "onView:agentForge.roster"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agent-forge",
          "title": "Agent Forge",
          "icon": "media/agent-forge.svg"
        }
      ]
    },
    "views": {
      "agent-forge": [
        {
          "id": "agentForge.dashboard",
          "name": "Dashboard",
          "type": "webview"
        },
        {
          "id": "agentForge.roster",
          "name": "Roster",
          "when": "agentForge.repoConfigured"
        }
      ]
    },
    "commands": [
      {
        "command": "agentForge.deploy",
        "title": "Deploy",
        "icon": "$(cloud-upload)",
        "category": "Agent Forge"
      },
      {
        "command": "agentForge.restore",
        "title": "Restore",
        "icon": "$(history)",
        "category": "Agent Forge"
      },
      {
        "command": "agentForge.wipe",
        "title": "Wipe",
        "icon": "$(trash)",
        "category": "Agent Forge"
      },
      {
        "command": "agentForge.status",
        "title": "Status",
        "icon": "$(info)",
        "category": "Agent Forge"
      },
      {
        "command": "agentForge.refresh",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "Agent Forge"
      },
      {
        "command": "agentForge.setRepoPath",
        "title": "Set Repository Path",
        "category": "Agent Forge"
      },
      {
        "command": "agentForge.openFile",
        "title": "Open File",
        "icon": "$(go-to-file)",
        "category": "Agent Forge"
      },
      {
        "command": "agentForge.enableSubAgents",
        "title": "Enable Sub-Agent Nesting",
        "category": "Agent Forge"
      },
      {
        "command": "agentForge.selectImageModel",
        "title": "Select Image Model",
        "icon": "$(device-camera)",
        "category": "Agent Forge"
      },
      {
        "command": "agentForge.openSettings",
        "title": "Open Settings",
        "icon": "$(gear)",
        "category": "Agent Forge"
      }
    ],
    "menus": {
      "view/title": [
        { "command": "agentForge.deploy", "when": "view == agentForge.roster", "group": "navigation@1" },
        { "command": "agentForge.restore", "when": "view == agentForge.roster", "group": "navigation@2" },
        { "command": "agentForge.wipe", "when": "view == agentForge.roster", "group": "navigation@3" },
        { "command": "agentForge.refresh", "when": "view == agentForge.roster", "group": "navigation@4" },
        { "command": "agentForge.status", "when": "view == agentForge.roster", "group": "navigation@5" },
        { "command": "agentForge.selectImageModel", "when": "view == agentForge.roster", "group": "navigation@6" },
        { "command": "agentForge.enableSubAgents", "when": "view == agentForge.roster", "group": "1_settings@1" },
        { "command": "agentForge.openSettings", "when": "view == agentForge.roster", "group": "1_settings@2" }
      ],
      "view/item/context": [
        { "command": "agentForge.openFile", "when": "view == agentForge.roster && viewItem == entry", "group": "inline" }
      ]
    },
    "configuration": {
      "title": "Agent Forge",
      "properties": {
        "agentForge.repoPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the roster Git repository"
        },
        "agentForge.autoConfirm": {
          "type": "boolean",
          "default": false,
          "description": "Skip confirmation for destructive operations"
        },
        "agentForge.imageModelStoragePath": {
          "type": "string",
          "default": "",
          "description": "Absolute path where image generation models are stored. Defaults to ~/.agent-forge/models if empty. Used by the graphic-designer agent."
        },
        "agentForge.generatedAssetsPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path where the graphic-designer stores generated and downloaded assets (logos, stock images, mockups). Defaults to the project's generated/ folder if empty."
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --watch"
  },
  "dependencies": {
    "@agent-forge/core": "*"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0"
  }
}
